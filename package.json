{
  "name": "toolcast",
  "version": "0.1.2",
  "description": "Turn any API into an AI agent tool. Point at an OpenAPI spec → get a working MCP server in 10 seconds.",
  "type": "module",
  "bin": {
    "toolcast": "dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "registry"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "openapi",
    "ai-agent",
    "claude",
    "tools",
    "api",
    "swagger",
    "llm"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "commander": "^13.0.0",
    "openapi-types": "^12.1.3",
    "yaml": "^2.7.0",
    "zod": "^3.24.0",
    "zod-to-json-schema": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Djsand/toolcast.git"
  },
  "homepage": "https://github.com/Djsand/toolcast",
  "engines": {
    "node": ">=18"
  }
}
